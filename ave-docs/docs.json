{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ave Docs",
  "description": "OAuth 2.0 + OpenID Connect integration docs for Ave, including PKCE, Connector, Signing, E2EE keys, and SDKs.",
  "colors": {
    "primary": "#6B7BFF"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "LLMs",
          "icon": "robot",
          "href": "https://aveid.net/llms.txt"
        }
      ]
    },
    "groups": [
      {
        "group": "Getting started",
        "pages": [
          "index",
          "quickstart",
          "reference/how-it-works",
          "reference/base-urls-and-concepts"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/oauth-authorization-code-flow",
          "guides/scopes-and-claims",
          "guides/pkce-for-public-clients",
          "guides/server-side-confidential-clients",
          "guides/convex-custom-auth",
          "guides/end-to-end-encryption",
          "guides/connector-app-to-app",
          "guides/ave-signing"
        ]
      },
      {
        "group": "SDKs",
        "pages": [
          "sdk/javascript-sdk",
          "sdk/embed-sdk",
          "sdk/expo-auth-bridge"
        ]
      },
      {
        "group": "API reference",
        "pages": [
          "api/overview",
          "api/oauth-endpoints",
          "api/signing-endpoints"
        ]
      },
      {
        "group": "Security",
        "pages": [
          "security/encryption-model-and-key-lifecycle",
          "security/best-practices"
        ]
      },
      {
        "group": "Troubleshooting",
        "pages": [
          "troubleshooting/common-mistakes-and-edge-cases"
        ]
      }
    ]
  },
  "metadata": {
    "timestamp": true
  },
  "errors": {
    "404": {
      "redirect": false,
      "title": "Page not found",
      "description": "The page you are looking for moved or no longer exists. Use the sidebar or search to find the latest integration guide."
    }
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/Lantharos/Ave"
      },
      {
        "label": "Developer Portal",
        "href": "https://devs.aveid.net"
      }
    ]
  }
}