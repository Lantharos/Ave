{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ave Docs",
  "description": "Not another login. Not another password. Just you.",
  "colors": {
    "primary": "#D3D3D3",
    "light": "#929292",
    "dark": "#b4b4b4"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "pages": [
          "index",
          "quickstart",
          "reference/how-it-works",
          "reference/base-urls-and-concepts"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/oauth-authorization-code-flow",
          "guides/scopes-and-claims",
          "guides/pkce-for-public-clients",
          "guides/server-side-confidential-clients",
          "guides/convex-custom-auth",
          "guides/end-to-end-encryption",
          "guides/connector-app-to-app",
          "guides/ave-signing"
        ]
      },
      {
        "group": "SDKs",
        "pages": [
          "sdk/javascript-sdk",
          "sdk/embed-sdk"
        ]
      },
      {
        "group": "API reference",
        "pages": [
          "api/overview",
          "api/oauth-endpoints",
          "api/signing-endpoints"
        ]
      },
      {
        "group": "Security",
        "pages": [
          "security/encryption-model-and-key-lifecycle",
          "security/best-practices"
        ]
      },
      {
        "group": "Troubleshooting",
        "pages": [
          "troubleshooting/common-mistakes-and-edge-cases"
        ]
      }
    ]
  },
  "metadata": {
    "timestamp": true
  },
  "errors": {
    "404": {
      "redirect": false,
      "title": "Page not found",
      "description": "The page you are looking for moved or no longer exists. Use the sidebar or search to find the latest integration guide."
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Developer Portal",
        "href": "https://devs.aveid.net"
      }
    ]
  },
  "favicon": "/images/Group6.png",
  "logo": "/images/Group6.png",
  "background": {
    "decoration": "gradient"
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "family": "Poppins",
    "weight": 500
  }
}