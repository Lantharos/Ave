  "metadata": {
    "timestamp": true
  },
  "errors": {
    "404": {
      "redirect": false,
      "title": "Page not found",
      "description": "The page you are looking for moved or no longer exists. Use the sidebar or search to find the latest integration guide."
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Developer Portal",
        "href": "https://devs.aveid.net"
      }
    ]
  },
  "favicon": "/images/Group6.png",
  "logo": "/images/Group6.png",
  "background": {
    "decoration": "gradient"
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "family": "Poppins",
    "weight": 500
  }
