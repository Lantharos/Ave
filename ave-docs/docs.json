          {
            "group": "Concepts",
            "pages": [
              "reference/how-it-works",
              "reference/base-urls-and-concepts"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Authentication",
            "pages": [
              "guides/quick-ave",
              "guides/oauth-authorization-code-flow",
              "guides/pkce-for-public-clients",
              "guides/server-side-confidential-clients",
              "guides/scopes-and-claims"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "guides/connector-app-to-app",
              "guides/ave-signing",
              "guides/end-to-end-encryption"
            ]
          },
          {
            "group": "Frameworks",
            "pages": [
              "guides/convex-custom-auth"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "SDKs",
            "pages": [
              "sdk/javascript-sdk",
              "sdk/embed-sdk"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "api/overview",
              "api/oauth-endpoints",
              "api/signing-endpoints"
            ]
          }
        ]
      },
      {
        "tab": "Security & Troubleshooting",
        "groups": [
          {
            "group": "Security",
            "pages": [
              "security/best-practices",
              "security/encryption-model-and-key-lifecycle"
            ]
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "troubleshooting/common-mistakes-and-edge-cases"
            ]
          }
        ]
      }
