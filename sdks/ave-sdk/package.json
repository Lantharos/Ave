{
  "name": "@ave-id/sdk",
  "version": "0.10.1",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./app-key": {
      "types": "./dist/app-key.d.ts",
      "default": "./dist/app-key.js"
    },
    "./app-encryption": {
      "types": "./dist/app-encryption.d.ts",
      "default": "./dist/app-encryption.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "default": "./dist/session.js"
    },
    "./session-storage": {
      "types": "./dist/session-storage.d.ts",
      "default": "./dist/session-storage.js"
    },
    "./convex": {
      "types": "./dist/convex.d.ts",
      "default": "./dist/convex.js"
    },
    "./svelte": {
      "types": "./dist/svelte.d.ts",
      "default": "./dist/svelte.js"
    },
    "./expo-lifecycle": {
      "types": "./dist/expo-lifecycle.d.ts",
      "default": "./dist/expo-lifecycle.js"
    },
    "./expo-session": {
      "types": "./dist/expo-session.d.ts",
      "default": "./dist/expo-session.js"
    },
    "./next": {
      "types": "./dist/next/react.d.ts",
      "default": "./dist/next/react.js"
    }
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "typescript": "^7.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Lantharos/Ave"
  }
}
