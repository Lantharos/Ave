{
  "name": "@ave-id/sdk",
  "version": "0.6.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "default": "./dist/session.js"
    },
    "./session-storage": {
      "types": "./dist/session-storage.d.ts",
      "default": "./dist/session-storage.js"
    },
    "./convex": {
      "types": "./dist/convex.d.ts",
      "default": "./dist/convex.js"
    },
    "./svelte": {
      "types": "./dist/svelte.d.ts",
      "default": "./dist/svelte.js"
    },
    "./expo-lifecycle": {
      "types": "./dist/expo-lifecycle.d.ts",
      "default": "./dist/expo-lifecycle.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
